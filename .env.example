# ============================================================
# 环境变量模板
# 使用方式：复制为 .env 并填入真实值
#          cp .env.example .env
#
# IDEA: Run Configuration → Environment Variables → 粘贴
# Docker: docker run --env-file .env ...
# Shell:  source .env  (或 export $(cat .env | xargs))
# ============================================================

# 数据库连接
DB_URL=jdbc:mysql://localhost:3306/word_test?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf-8&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_password_here

# 服务端口
SERVER_PORT=8080
