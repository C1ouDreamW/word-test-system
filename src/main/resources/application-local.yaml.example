# ============================================================
# 本地开发配置文件模板
# 使用方式：复制为 application-local.yaml 并填入你的真实值
#          cp application-local.yaml.example application-local.yaml
#
# Spring Boot 会自动加载 application-local.yaml
# 启动时指定: --spring.profiles.active=local
# 或在 application.yaml 中设置 spring.profiles.active: local
# ============================================================

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/word_test?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf-8&allowPublicKeyRetrieval=true
    username: root
    password: your_password_here   # <-- 改成你的真实密码

server:
  port: 8080
